# ============================================================
#  ZEUS — Variabili d'ambiente per il server cloud
#  Copia questo file in /opt/zeus/.env e compila i valori.
#  chmod 600 /opt/zeus/.env   (solo l'utente zeus puo' leggerlo)
# ============================================================

# LLM (DeepSeek — compatibile OpenAI)
LLM_API_KEY=sk-INSERISCI_QUI_LA_TUA_CHIAVE_DEEPSEEK
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat

# Zep (memoria degli agenti MiroFish)
ZEP_API_KEY=INSERISCI_QUI_LA_TUA_CHIAVE_ZEP

# Telegram (Hermes briefing mattutino)
TELEGRAM_BOT_TOKEN=INSERISCI_QUI_IL_TOKEN_DEL_BOT
TELEGRAM_CHAT_ID=INSERISCI_QUI_IL_TUO_CHAT_ID

# GitHub (per il push automatico del report)
# Crea un Personal Access Token su github.com/settings/tokens
# Scope necessario: repo (write)
GITHUB_TOKEN=INSERISCI_QUI_IL_TOKEN_GITHUB
GITHUB_REPO=polyglottentacle/zeus-reports

# Zeus — modalita' operativa (NON CAMBIARE)
MODE=PAPER
CONFIRM_LIVE_TRADING=NO

# MiroFish — configurazione
MAX_MIROFISH_AGENTS=40
MAX_MIROFISH_ROUNDS=20
MIROFISH_TIMEOUT_SECONDS=900

# Report URL (usato da Hermes per leggere da GitHub)
ZEUS_REPORT_URL=https://raw.githubusercontent.com/polyglottentacle/zeus-reports/main/output/daily_report.json
