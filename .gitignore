# Python cache and artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore output files except the daily report and zeus_signal
output/*
!output/daily_report.json
!output/zeus_signal.json

# Ignore generated scheduler/runtime files
output/scheduler.log
output/strategy_status.json

# Ignore installed repos and local sensitive files
freqtrade/
MiroFish/
MiroFish/node_modules/
MiroFish/**/__pycache__/
hostinger credenziali.txt

# TradingAgents (ochi) — venv e cache locali
ochi/venv/
ochi/.cache/
ochi/.results/
ochi/__pycache__/
ochi/**/__pycache__/

# SECRETS — chiavi API, mai su GitHub
.env
*.env
.env.*
secrets/
*secret*
*credenziali*

# Common editor/temp files
*.swp
*.swo
.DS_Store
